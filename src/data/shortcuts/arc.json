    { "action": "Change current tab URL", "windows": "Ctrl+L", "mac": "Cmd+L", "category": "Address bar", "difficulty": "beginner" },
    { "action": "View History", "windows": "Ctrl+H", "mac": "Cmd+Y", "category": "General", "difficulty": "beginner" },
