{
  "app": "firefox",
  "officialDocsUrl": "https://support.mozilla.org/en-US/kb/keyboard-shortcuts-perform-firefox-tasks-quickly",
  "lastVerified": "2026-07-16",
  "shortcuts": [
    { "action": "New tab", "windows": "Ctrl+T", "mac": "Cmd+T", "category": "Tabs", "difficulty": "beginner" },
    { "action": "Close tab", "windows": "Ctrl+W", "mac": "Cmd+W", "category": "Tabs", "difficulty": "beginner" },
    { "action": "Reopen last closed tab", "windows": "Ctrl+Shift+T", "mac": "Cmd+Shift+T", "category": "Tabs", "difficulty": "beginner" },
    { "action": "Go one tab to the right", "windows": "Ctrl+Tab", "mac": "Ctrl+Tab", "category": "Tabs", "difficulty": "intermediate" },
    { "action": "Go one tab to the left", "windows": "Ctrl+Shift+Tab", "mac": "Ctrl+Shift+Tab", "category": "Tabs", "difficulty": "intermediate" },
    { "action": "Go to tab 1 to 8", "windows": "Ctrl+1 ... Ctrl+8", "mac": "Cmd+1 ... Cmd+8", "category": "Tabs", "difficulty": "intermediate" },
    { "action": "Go to last tab", "windows": "Ctrl+9", "mac": "Cmd+9", "category": "Tabs", "difficulty": "intermediate" },
    { "action": "Mute or unmute audio", "windows": "Ctrl+M", "mac": "Ctrl+M", "category": "Tabs", "difficulty": "advanced" },
    { "action": "New window", "windows": "Ctrl+N", "mac": "Cmd+N", "category": "Windows", "difficulty": "beginner" },
    { "action": "New private window", "windows": "Ctrl+Shift+P", "mac": "Cmd+Shift+P", "category": "Windows", "difficulty": "beginner" },
    { "action": "Reopen last closed window", "windows": "Ctrl+Shift+N", "mac": "Cmd+Shift+N", "category": "Windows", "difficulty": "intermediate" },
    { "action": "Quit Firefox", "windows": "Ctrl+Shift+Q", "mac": "Cmd+Q", "category": "Windows", "difficulty": "intermediate" },
    { "action": "Go back", "windows": "Alt+Left", "mac": "Cmd+Left", "category": "Navigation", "difficulty": "beginner" },
    { "action": "Go forward", "windows": "Alt+Right", "mac": "Cmd+Right", "category": "Navigation", "difficulty": "beginner" },
    { "action": "Reload", "windows": "Ctrl+R", "mac": "Cmd+R", "category": "Navigation", "difficulty": "beginner" },
    { "action": "Reload (override cache)", "windows": "Ctrl+Shift+R", "mac": "Cmd+Shift+R", "category": "Navigation", "difficulty": "intermediate" },
    { "action": "Home", "windows": "Alt+Home", "mac": "Option+Home", "category": "Navigation", "difficulty": "intermediate" },
    { "action": "Toggle full screen", "windows": "F11", "mac": "Cmd+Shift+F", "category": "General", "difficulty": "intermediate" },
    { "action": "Focus address bar", "windows": "Ctrl+L", "mac": "Cmd+L", "category": "Address bar", "difficulty": "beginner" },
    { "action": "Focus address bar for web search", "windows": "Ctrl+K", "mac": "Cmd+K", "category": "Address bar", "difficulty": "intermediate" },
    { "action": "Complete .com address", "windows": "Ctrl+Enter", "mac": "Ctrl+Enter", "category": "Address bar", "difficulty": "advanced" },
    { "action": "Bookmark this page", "windows": "Ctrl+D", "mac": "Cmd+D", "category": "Bookmarks", "difficulty": "beginner" },
    { "action": "Bookmark all tabs", "windows": "Ctrl+Shift+D", "mac": "Cmd+Shift+D", "category": "Bookmarks", "difficulty": "advanced" },
    { "action": "Show or hide the bookmarks toolbar", "windows": "Ctrl+Shift+B", "mac": "Cmd+Shift+B", "category": "Bookmarks", "difficulty": "intermediate" },
    { "action": "Show all bookmarks (Library window)", "windows": "Ctrl+Shift+O", "mac": "Cmd+Shift+O", "category": "Bookmarks", "difficulty": "intermediate" },
    { "action": "Find in this page", "windows": "Ctrl+F", "mac": "Cmd+F", "category": "General", "difficulty": "beginner" },
    { "action": "History sidebar", "windows": "Ctrl+H", "mac": "Cmd+Shift+H", "category": "General", "difficulty": "beginner" },
    { "action": "Downloads", "windows": "Ctrl+J", "mac": "Cmd+J", "category": "General", "difficulty": "beginner" },
    { "action": "Clear recent history", "windows": "Ctrl+Shift+Delete", "mac": "Cmd+Shift+Delete", "category": "General", "difficulty": "intermediate" }
  ]
